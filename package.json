{
    "name": "jsknx-monorepo",
    "private": true,
    "workspaces": [
        "packages/*",
        "apps/*"
    ],
    "scripts": {
        "clean": "turbo run clean",
        "build": "turbo run build",
        "test": "turbo run test",
        "lint": "turbo run lint",
        "lint:ci": "turbo run lint:ci",
        "typecheck": "turbo run typecheck",
        "format": "prettier --write .",
        "format:ci": "prettier --check .",
        "dev": "turbo run dev"
    },
    "devDependencies": {
        "@eslint/js": "^9.28.0",
        "@types/jest": "^29.5.14",
        "@types/node": "^24.0.3",
        "eslint": "^9.28.0",
        "eslint-config-prettier": "^10.1.5",
        "jest": "^29.7.0",
        "prettier": "^3.5.3",
        "ts-jest": "^29.3.4",
        "ts-node": "^10.9.2",
        "turbo": "^2.5.4",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.33.0"
    },
    "packageManager": "yarn@1.22.22",
    "engines": {
        "node": ">=20"
    }
}
