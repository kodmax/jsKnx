        "lint": "eslint . --fix",
        "lint:ci": "eslint .",
        "typecheck": "tsc --noEmit",
        "dev": "ts-node src",
        "prepublishOnly": "npm run build && npm test"
    },
    "author": "Marcin Malinowski <mm.kodmax@gmail.com>",
    "license": "GPL-3.0",
    "devDependencies": {
        "@eslint/js": "^9.28.0",
        "@types/jest": "^29.5.14",
        "@types/node": "^24.0.3",
        "eslint": "^9.28.0",
        "eslint-config-prettier": "^10.1.5",
        "jest": "^29.7.0",
        "prettier": "^3.5.3",
        "ts-jest": "^29.3.4",
        "ts-node": "^10.9.2",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.33.0"
    },
    "bin": {
        "knx-write": "./bin/write.js",
        "knx-read": "./bin/read.js"
    }
