{
    "name": "js-knx",
    "version": "2.18.0",
    "description": "KNX IP/Gateway client",
    "repository": {
        "type": "git",
        "url": "https://github.com/kodmax/jsKnx.git"
    },
    "bugs": {
        "url": "https://github.com/kodmax/jsKnx/issues"
    },
    "homepage": "https://github.com/kodmax/jsKnx#readme",
    "keywords": [
        "KNX"
    ],
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist",
        "bin",
        "LICENSE.md",
        "README.md"
    ],
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "build": "tsc",
        "test": "jest",
